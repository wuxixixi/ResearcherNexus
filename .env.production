# 应用设置
DEBUG=False
APP_ENV=production

# 搜索引擎设置
SEARCH_API=duckduckgo
TAVILY_API_KEY=your_tavily_api_key_here
# JINA_API_KEY=your_jina_api_key_here  # 可选

# 火山引擎TTS（可选）
VOLCENGINE_TTS_APPID=your_appid_here
VOLCENGINE_TTS_ACCESS_TOKEN=your_access_token_here
# VOLCENGINE_TTS_CLUSTER=volcano_tts
# VOLCENGINE_TTS_VOICE_TYPE=BV700_V2_streaming

# LangSmith设置
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=ResearchNexus-Production
LANGCHAIN_TRACING=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_TAGS=prod,production

# API设置
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 缓存设置
CACHE_ENABLED=true
CACHE_TTL=3600  # 缓存有效期（秒）

# 数据库设置（可选）
# DATABASE_URL=postgresql://username:password@hostname:port/database

# 服务器设置
MAX_WORKERS=4
WORKER_TIMEOUT=300 