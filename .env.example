# Application Settings
DEBUG=True
APP_ENV=development

# Search Engine
SEARCH_API=duckduckgo
TAVILY_API_KEY=unused
# JINA_API_KEY=jina_xxx # Optional, default is None

# Optional, volcengine TTS for generating podcast
VOLCENGINE_TTS_APPID=xxx
VOLCENGINE_TTS_ACCESS_TOKEN=xxx
# VOLCENGINE_TTS_CLUSTER=volcano_tts # Optional, default is volcano_tts
# VOLCENGINE_TTS_VOICE_TYPE=BV700_V2_streaming # Optional, default is BV700_V2_streaming

# [!NOTE]
# For model settings and other configurations, please refer to `docs/configuration_guide.md`

# LangSmith Configuration
# Get your API key from https://smith.langchain.com/
LANGCHAIN_API_KEY=your_api_key_here
LANGCHAIN_PROJECT=ResearchNexus
LANGCHAIN_TRACING=true
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com # Optional, default is https://api.smith.langchain.com
# LANGCHAIN_TAGS=prod,v1,research # Optional, comma-separated tags
